+package com.android.server.location;
+
+import android.annotation.Nullable;
+import android.content.pm.GosPackageState;
+import android.content.pm.GosPackageStateFlag;
+import android.ext.lscopes.LocationScopesApi;
+import android.ext.lscopes.LocationScopesConfig;
+import android.location.Location;
+import android.location.LocationResult;
+import android.location.util.identity.CallerIdentity;
+import android.os.SystemClock;
+
+import java.security.SecureRandom;
+import java.util.HashMap;
+
+/**
+ * Applies Location Scopes policy to location data immediately before it is delivered to an app.
+ *
+ * All transform logic is centralised here. The three hook sites in
+ * {@link com.android.server.location.provider.LocationProviderManager} each make a single
+ * static call into this class; nothing else in the location stack is changed.
+ *
+ * Modes:
+ *   MODE_NORMAL — data passes through unchanged.
+ *   MODE_NOISY  — coordinates are displaced by a Gaussian random offset within radiusMeters.
+ *   MODE_FIXED  — coordinates are replaced by the configured lat/lon/alt plus hairline jitter.
+ *
+ * GNSS raw measurements are suppressed in MODE_FIXED via {@link #shouldBlockGnssMeasurements}.
+ *
+ * @hide
+ */
+public final class LocationScopesInterceptor {
+
+    private static final SecureRandom sRandom = new SecureRandom();
+
+    // Approximate metres per degree of latitude (constant at all latitudes).
+    private static final double METERS_PER_DEGREE_LAT = 111_000.0;
+
+    // Small jitter applied in FIXED mode to prevent a perfectly static coordinate.
+    private static final float FIXED_JITTER_METERS = 2f;
+
+    // Per-request micro-jitter applied on top of the cached noisy center.
+    // Small enough that averaging many samples still cannot recover the true location
+    // (the cached center is already displaced by radiusMeters), but large enough to
+    // prevent an obviously static output.
+    private static final float NOISY_JITTER_METERS = 2f;
+
+    // Accuracy reported for fixed-mode locations — looks like a perfect GPS fix.
+    private static final float FIXED_ACCURACY_M = 5.0f;
+
+    // Altitude fuzz standard deviation as a fraction of the horizontal radius.
+    // Keeps altitude noise plausible (a few metres at typical radii) without requiring
+    // a separate user-configurable parameter.
+    private static final float ALTITUDE_FUZZ_RATIO = 0.05f;
+
+    /**
+     * Cached noisy center for one UID.
+     *
+     * The center is an absolute coordinate derived from the true location at the time the entry
+     * was created, displaced by a Gaussian random offset. Subsequent deliveries return this
+     * absolute center plus micro-jitter, so the reported position stays anchored even as the
+     * device moves underneath.
+     *
+     * {@code lastAccessElapsedRealtimeMs} is updated on each reuse so the TTL is
+     * measured from last access, not from creation.
+     */
+    private static final class NoisyCacheEntry {
+        final double cachedLat;
+        final double cachedLon;
+        // NaN when the source had no altitude at cache-fill time; lazily filled on
+        // the first subsequent delivery that does carry altitude.
+        double cachedAltM;
+        final int generation;
+        long lastAccessElapsedRealtimeMs;
+
+        NoisyCacheEntry(double cachedLat, double cachedLon, double cachedAltM,
+                int generation, long lastAccessElapsedRealtimeMs) {
+            this.cachedLat = cachedLat;
+            this.cachedLon = cachedLon;
+            this.cachedAltM = cachedAltM;
+            this.generation = generation;
+            this.lastAccessElapsedRealtimeMs = lastAccessElapsedRealtimeMs;
+        }
+    }
+
+    // Guarded by itself. Keyed by UID.
+    private static final HashMap<Integer, NoisyCacheEntry> sNoisyCache = new HashMap<>();
+
+    /**
+     * Applies Location Scopes policy to a {@link LocationResult} before delivery.
+     *
+     * Returns {@code null} when the input is {@code null} (preserving the
+     * null-means-timeout contract used by {@code getCurrentLocation}).
+     */
+    @Nullable
+    public static LocationResult applyPolicy(
+            @Nullable LocationResult result, CallerIdentity identity) {
+        if (result == null) {
+            return null;
+        }
+        return result.map(loc -> applyPolicy(loc, identity));
+    }
+
+    /**
+     * Applies Location Scopes policy to a single {@link Location} before delivery.
+     *
+     * Returns {@code null} only when the input is {@code null}.
+     */
+    @Nullable
+    public static Location applyPolicy(@Nullable Location location, CallerIdentity identity) {
+        if (location == null) {
+            return null;
+        }
+
+        GosPackageState gosPs = GosPackageState.get(
+                identity.getPackageName(), identity.getUserId());
+        if (!gosPs.hasFlag(GosPackageStateFlag.LOCATION_SCOPES_ENABLED)) {
+            return location;
+        }
+
+        LocationScopesConfig cfg = LocationScopesConfig.deserialize(gosPs.locationScopes);
+        switch (cfg.mode) {
+            case LocationScopesApi.MODE_NOISY:
+                return applyNoisy(location, cfg, identity.getUid());
+            case LocationScopesApi.MODE_FIXED:
+                return applyFixed(location, cfg);
+            default: // MODE_NORMAL
+                return location;
+        }
+    }
+
+    /**
+     * Returns {@code true} if raw GNSS measurements should be suppressed for the given identity.
+     *
+     * Suppression is active only in MODE_FIXED: in that mode raw satellite data would let a
+     * determined app cross-check and detect the spoofed coordinates. In MODE_NOISY the real
+     * satellite constellation does not contradict a nearby-but-fuzzed position.
+     */
+    public static boolean shouldBlockGnssMeasurements(CallerIdentity identity) {
+        GosPackageState gosPs = GosPackageState.get(
+                identity.getPackageName(), identity.getUserId());
+        if (!gosPs.hasFlag(GosPackageStateFlag.LOCATION_SCOPES_ENABLED)) {
+            return false;
+        }
+        LocationScopesConfig cfg = LocationScopesConfig.deserialize(gosPs.locationScopes);
+        return cfg.mode == LocationScopesApi.MODE_FIXED;
+    }
+
+    // --- private transforms ------------------------------------------------------------------
+
+    private static Location applyNoisy(Location src, LocationScopesConfig cfg, int uid) {
+        double[] center = getCachedNoisyCenter(src, cfg, uid);
+        Location out = applyWithJitter(src, center[0], center[1], NOISY_JITTER_METERS,
+                Math.max(src.getAccuracy(), cfg.radiusMeters));
+        // center[2] is the cached fuzzed altitude, or NaN if altitude was never available.
+        if (!Double.isNaN(center[2])) {
+            out.setAltitude(center[2] + gaussianScalarMeters(NOISY_JITTER_METERS));
+        } else {
+            out.removeAltitude();
+        }
+        return out;
+    }
+
+    /**
+     * Returns {@code [cachedLat, cachedLon, cachedAltM]} for {@code uid}.
+     *
+     * {@code cachedAltM} is {@link Double#NaN} when no altitude has yet been seen for this
+     * cache epoch. It is lazily populated on the first delivery that carries altitude, so a
+     * cache hit with {@code NaN} altitude that now has a source altitude will update the entry
+     * in place rather than treating the absence as permanent.
+     */
+    private static double[] getCachedNoisyCenter(
+            Location src, LocationScopesConfig cfg, int uid) {
+        long now = SystemClock.elapsedRealtime();
+        float altStdDevM = cfg.radiusMeters * ALTITUDE_FUZZ_RATIO;
+        synchronized (sNoisyCache) {
+            NoisyCacheEntry entry = sNoisyCache.get(uid);
+            if (entry != null
+                    && entry.generation == cfg.generation
+                    && now - entry.lastAccessElapsedRealtimeMs <= cfg.noisyTtlMs) {
+                // Lazily derive altitude if this is the first delivery with altitude in the epoch.
+                if (Double.isNaN(entry.cachedAltM) && src.hasAltitude()) {
+                    entry.cachedAltM = src.getAltitude() + gaussianScalarMeters(altStdDevM);
+                }
+                entry.lastAccessElapsedRealtimeMs = now;
+                return new double[]{entry.cachedLat, entry.cachedLon, entry.cachedAltM};
+            }
+            // Cache miss or stale — displace the current true location and anchor there.
+            double[] offsets = gaussianOffsetDegrees(src.getLatitude(), cfg.radiusMeters);
+            double centerLat = src.getLatitude() + offsets[0];
+            double centerLon = src.getLongitude() + offsets[1];
+            double centerAlt = src.hasAltitude()
+                    ? src.getAltitude() + gaussianScalarMeters(altStdDevM)
+                    : Double.NaN;
+            sNoisyCache.put(uid, new NoisyCacheEntry(
+                    centerLat, centerLon, centerAlt, cfg.generation, now));
+            return new double[]{centerLat, centerLon, centerAlt};
+        }
+    }
+
+    private static Location applyFixed(Location src, LocationScopesConfig cfg) {
+        Location out = applyWithJitter(src, cfg.latitude, cfg.longitude,
+                FIXED_JITTER_METERS, FIXED_ACCURACY_M);
+        out.setAltitude(cfg.altitude);
+        return out;
+    }
+
+    /**
+     * Returns a copy of {@code src} with coordinates replaced by
+     * {@code (baseLat, baseLon) + Gaussian(jitterMeters)} and accuracy set to
+     * {@code accuracy}. Altitude is preserved from {@code src} unless the caller overrides it.
+     */
+    private static Location applyWithJitter(
+            Location src, double baseLat, double baseLon, float jitterMeters, float accuracy) {
+        double[] jitter = gaussianOffsetDegrees(baseLat, jitterMeters);
+        Location out = new Location(src);
+        out.setLatitude(baseLat + jitter[0]);
+        out.setLongitude(baseLon + jitter[1]);
+        out.setAccuracy(accuracy);
+        out.setMock(false);
+        return out;
+    }
+
+    /**
+     * Returns a {@code [latOffsetDegrees, lonOffsetDegrees]} pair drawn from a 2-D Gaussian
+     * distribution with the given standard deviation in metres, centred on {@code refLatitude}.
+     *
+     * Uses the Box–Muller transform. The longitude conversion accounts for convergence of
+     * meridians at high latitudes.
+     */
+    private static double[] gaussianOffsetDegrees(double refLatitude, float radiusMeters) {
+        double u1;
+        do {
+            u1 = sRandom.nextDouble();
+        } while (u1 == 0.0); // guard against log(0)
+        double u2 = sRandom.nextDouble();
+
+        double magnitude = radiusMeters * Math.sqrt(-2.0 * Math.log(u1));
+        double angle = 2.0 * Math.PI * u2;
+        double dx = magnitude * Math.cos(angle);
+        double dy = magnitude * Math.sin(angle);
+
+        double metersPerDegLon =
+                METERS_PER_DEGREE_LAT * Math.cos(Math.toRadians(refLatitude));
+        double latOffset = dx / METERS_PER_DEGREE_LAT;
+        double lonOffset = (metersPerDegLon > 0.0) ? dy / metersPerDegLon : 0.0;
+
+        return new double[]{latOffset, lonOffset};
+    }
+
+    /**
+     * Returns a scalar value drawn from a 1-D Gaussian distribution with the given
+     * standard deviation in metres. Uses one component of the Box–Muller transform.
+     */
+    private static double gaussianScalarMeters(float stdDevMeters) {
+        double u1;
+        do {
+            u1 = sRandom.nextDouble();
+        } while (u1 == 0.0);
+        double u2 = sRandom.nextDouble();
+        return stdDevMeters * Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0 * Math.PI * u2);
+    }
+
+    private LocationScopesInterceptor() {}
+}
