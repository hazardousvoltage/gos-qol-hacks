@@ -0,0 +1,28 @@
+package android.ext.lscopes;
+
+import android.annotation.NonNull;
+import android.annotation.SystemApi;
+import android.content.ComponentName;
+import android.content.Intent;
+
+/** @hide */
+@SystemApi
+public final class LocationScopesApi {
+
+    public static final int MODE_NORMAL = 0;
+    public static final int MODE_NOISY = 1;
+    public static final int MODE_FIXED = 2;
+
+    public static final float DEFAULT_FUZZ_RADIUS_M = 500f;
+
+    @NonNull
+    public static Intent createConfigActivityIntent(@NonNull String targetPkg) {
+        var i = new Intent();
+        String pkg = "com.android.permissioncontroller";
+        i.setComponent(ComponentName.createRelative(pkg, ".lscopes.LocationScopesActivity"));
+        i.putExtra(Intent.EXTRA_PACKAGE_NAME, targetPkg);
+        return i;
+    }
+
+    private LocationScopesApi() {}
+}
diff --git a/core/java/android/ext/lscopes/LocationScopesConfig.java b/core/java/android/ext/lscopes/LocationScopesConfig.java
new file mode 100644
index 000000000000..a391ec9d0035
--- /dev/null
+++ b/core/java/android/ext/lscopes/LocationScopesConfig.java
@@ -0,0 +1,168 @@
+package android.ext.lscopes;
+
+import android.annotation.IntDef;
+import android.annotation.NonNull;
+import android.annotation.Nullable;
+import android.annotation.SystemApi;
+import android.util.Log;
+
+import java.io.ByteArrayInputStream;
+import java.io.ByteArrayOutputStream;
+import java.io.DataInputStream;
+import java.io.DataOutputStream;
+import java.lang.annotation.Retention;
+import java.lang.annotation.RetentionPolicy;
+import java.util.Objects;
+
+/** @hide */
+@SystemApi
+public final class LocationScopesConfig {
+    private static final String TAG = "LocationScopesConfig";
+    private static final int VERSION = 1;
+    private static final int VERSION_LEGACY = 0;
+
+    // Default TTL: 24 hours in milliseconds. Long enough to survive typical usage sessions
+    // without re-averaging risk; user can lower it or trigger manual refresh at any time.
+    public static final long DEFAULT_NOISY_TTL_MS = 24L * 60 * 60 * 1000;
+
+    // Hard ceiling to prevent overflow in elapsed-realtime delta arithmetic.
+    private static final long MAX_NOISY_TTL_MS = 30L * 24 * 60 * 60 * 1000; // 30 days
+
+    @IntDef(prefix = "MODE_", value = {
+            LocationScopesApi.MODE_NORMAL,
+            LocationScopesApi.MODE_NOISY,
+            LocationScopesApi.MODE_FIXED,
+    })
+    @Retention(RetentionPolicy.SOURCE)
+        @interface Mode {}
+
+    @Mode public final int mode;
+    public final double latitude;
+    public final double longitude;
+    public final double altitude;
+    public final float radiusMeters;
+    /** Milliseconds since last access before the noisy center is rotated. Must be > 0. */
+    public final long noisyTtlMs;
+    /**
+     * Monotonic cache epoch. Incrementing this value immediately invalidates the in-process
+     * noisy center for this app's UID without requiring a process kill.
+     */
+    public final int generation;
+
+    public LocationScopesConfig(@Mode int mode, double latitude, double longitude,
+            double altitude, float radiusMeters, long noisyTtlMs, int generation) {
+        this.mode = mode;
+        this.latitude = latitude;
+        this.longitude = longitude;
+        this.altitude = altitude;
+        this.radiusMeters = radiusMeters;
+        this.noisyTtlMs = clampTtl(noisyTtlMs);
+        this.generation = generation;
+    }
+
+    @NonNull
+    public static LocationScopesConfig defaultConfig() {
+        return new LocationScopesConfig(
+                LocationScopesApi.MODE_NOISY,
+                0d,
+                0d,
+                0d,
+                LocationScopesApi.DEFAULT_FUZZ_RADIUS_M,
+                DEFAULT_NOISY_TTL_MS,
+                0
+        );
+    }
+
+    @NonNull
+    public byte[] serialize() {
+        ByteArrayOutputStream bos = new ByteArrayOutputStream(80);
+        DataOutputStream out = new DataOutputStream(bos);
+        try {
+            out.writeByte(VERSION);
+            out.writeByte(mode);
+            out.writeDouble(latitude);
+            out.writeDouble(longitude);
+            out.writeDouble(altitude);
+            out.writeFloat(radiusMeters);
+            out.writeLong(noisyTtlMs);
+            out.writeInt(generation);
+            return bos.toByteArray();
+        } catch (Exception e) {
+            throw new IllegalStateException(e);
+        }
+    }
+
+    @NonNull
+    public static LocationScopesConfig deserialize(@Nullable byte[] serialized) {
+        if (serialized == null) {
+            return defaultConfig();
+        }
+
+        DataInputStream in = new DataInputStream(new ByteArrayInputStream(serialized));
+        try {
+            int version = in.readByte();
+            if (version != VERSION && version != VERSION_LEGACY) {
+                Log.e(TAG, "unexpected version " + version);
+                return defaultConfig();
+            }
+
+            int mode = in.readByte();
+            double latitude = in.readDouble();
+            double longitude = in.readDouble();
+            double altitude = in.readDouble();
+            float radiusMeters = in.readFloat();
+
+            if (mode < LocationScopesApi.MODE_NORMAL || mode > LocationScopesApi.MODE_FIXED) {
+                Log.e(TAG, "invalid mode " + mode);
+                return defaultConfig();
+            }
+
+            // v0 payloads end here; supply defaults for the new fields.
+            if (version == VERSION_LEGACY) {
+                return new LocationScopesConfig(mode, latitude, longitude, altitude, radiusMeters,
+                        DEFAULT_NOISY_TTL_MS, 0);
+            }
+
+            long noisyTtlMs = in.readLong();
+            int generation = in.readInt();
+
+            if (noisyTtlMs <= 0) {
+                Log.w(TAG, "non-positive noisyTtlMs " + noisyTtlMs + ", using default");
+                noisyTtlMs = DEFAULT_NOISY_TTL_MS;
+            }
+
+            return new LocationScopesConfig(mode, latitude, longitude, altitude, radiusMeters,
+                    noisyTtlMs, generation);
+        } catch (Exception e) {
+            Log.e(TAG, "deserialization failed", e);
+            return defaultConfig();
+        }
+    }
+
+    private static long clampTtl(long ttlMs) {
+        if (ttlMs <= 0) return DEFAULT_NOISY_TTL_MS;
+        return Math.min(ttlMs, MAX_NOISY_TTL_MS);
+    }
+
+    @Override
+    public boolean equals(Object obj) {
+        if (!(obj instanceof LocationScopesConfig)) {
+            return false;
+        }
+
+        LocationScopesConfig other = (LocationScopesConfig) obj;
+        return mode == other.mode
+                && Double.compare(latitude, other.latitude) == 0
+                && Double.compare(longitude, other.longitude) == 0
+                && Double.compare(altitude, other.altitude) == 0
+                && Float.compare(radiusMeters, other.radiusMeters) == 0
+                && noisyTtlMs == other.noisyTtlMs
+                && generation == other.generation;
+    }
+
+    @Override
+    public int hashCode() {
+        return Objects.hash(mode, latitude, longitude, altitude, radiusMeters, noisyTtlMs,
+                generation);
+    }
+}
