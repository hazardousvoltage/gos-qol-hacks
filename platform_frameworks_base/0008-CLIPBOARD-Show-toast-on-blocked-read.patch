+        if (op == AppOpsManager.OP_READ_CLIPBOARD) {
+            synchronized (mLock) {
+                Clipboard clipboard = getClipboardLocked(userId, intendingDeviceId);
+                if (clipboard != null && clipboard.primaryClip != null
+                        && UserHandle.isSameApp(uid, clipboard.primaryClipUid)) {
