+package android.hardware.fingerprint;
+
+import android.annotation.NonNull;
+import android.os.Parcel;
+import android.os.Parcelable;
+
+/**
+ * Container for duress fingerprint configuration.
+ * @hide
+ */
+public final class DuressConfig implements Parcelable {
+    private final int mUserId;
+    private final int mDuressFingerprintId;
+    private final long mUpdatedAtMs;
+
+    public DuressConfig(int userId, int duressFingerprintId, long updatedAtMs) {
+        mUserId = userId;
+        mDuressFingerprintId = duressFingerprintId;
+        mUpdatedAtMs = updatedAtMs;
+    }
+
+    private DuressConfig(Parcel in) {
+        mUserId = in.readInt();
+        mDuressFingerprintId = in.readInt();
+        mUpdatedAtMs = in.readLong();
+    }
+
+    public int getUserId() {
+        return mUserId;
+    }
+
+    public int getDuressFingerprintId() {
+        return mDuressFingerprintId;
+    }
+
+    public long getUpdatedAtMs() {
+        return mUpdatedAtMs;
+    }
+
+    @Override
+    public int describeContents() {
+        return 0;
+    }
+
+    @Override
+    public void writeToParcel(@NonNull Parcel dest, int flags) {
+        dest.writeInt(mUserId);
+        dest.writeInt(mDuressFingerprintId);
+        dest.writeLong(mUpdatedAtMs);
+    }
+
+    public static final @NonNull Creator<DuressConfig> CREATOR = new Creator<>() {
+        @Override
+        public DuressConfig createFromParcel(Parcel source) {
+            return new DuressConfig(source);
+        }
+
+        @Override
+        public DuressConfig[] newArray(int size) {
+            return new DuressConfig[size];
+        }
+    };
+}
