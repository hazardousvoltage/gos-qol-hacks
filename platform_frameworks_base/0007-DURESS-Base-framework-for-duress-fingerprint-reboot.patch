+package com.android.server.biometrics.sensors.fingerprint;
+
+import android.content.Context;
+import android.os.PowerManager;
+import android.util.Slog;
+
+/**
+ * Handles the duress fingerprint reboot sequence. When a designated duress fingerprint is
+ * authenticated on the keyguard, this class immediately requests a normal reboot. On reboot the
+ * device returns to before-first-unlock (FBE-locked) state, preventing access to user data.
+ */
+public class DuressRebootHandler {
+
+    private static final String TAG = "DuressRebootHandler";
+
+    /**
+     * Reason string passed to {@link PowerManager#reboot}. Visible in logs and
+     * last_kmsg to aid post-incident analysis.
+     */
+    private static final String REBOOT_REASON = "duress";
+
+    private DuressRebootHandler() {}
+
+    /**
+     * Requests an immediate reboot.
+     *
+     * @param context a {@link Context} that can resolve {@link PowerManager}
+     */
+    public static void triggerDuressReboot(@android.annotation.NonNull Context context) {
+        PowerManager pm = context.getSystemService(PowerManager.class);
+        if (pm != null) {
+            Slog.i(TAG, "Executing duress reboot");
+            try {
+                pm.reboot(REBOOT_REASON);
+            } catch (RuntimeException e) {
+                Slog.e(TAG, "Duress reboot failed", e);
+            }
+        } else {
+            Slog.e(TAG, "PowerManager unavailable, duress reboot aborted");
+        }
+    }
+}
