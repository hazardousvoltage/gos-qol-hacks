+
+    public void setDuressFingerprint(int fingerId) {
+        synchronized (this) {
+            boolean changed = false;
+            for (int i = 0; i < mBiometrics.size(); i++) {
+                final Fingerprint fp = mBiometrics.get(i);
+                final boolean shouldBeDuress = fingerId != Fingerprint.DURESS_FINGERPRINT_NONE
+                        && fp.getBiometricId() == fingerId;
+                if (fp.isDuress() != shouldBeDuress) {
+                    fp.setDuress(shouldBeDuress);
+                    changed = true;
+                }
+            }
+
+            if (changed) {
+                scheduleWriteStateLocked();
+            }
+        }
+    }
+
+    public int getDuressFingerprintId() {
+        synchronized (this) {
+            for (int i = 0; i < mBiometrics.size(); i++) {
+                final Fingerprint fp = mBiometrics.get(i);
+                if (fp.isDuress()) {
+                    return fp.getBiometricId();
+                }
+            }
+            return Fingerprint.DURESS_FINGERPRINT_NONE;
+        }
+    }
 }
