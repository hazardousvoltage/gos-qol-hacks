+    /**
+     * Marks the provided fingerprint as duress for the given user.
+     *
+     * @hide
+     */
+    @RequiresPermission(MANAGE_FINGERPRINT)
+    public void setDuressFingerprint(int userId, int fpId) {
+        if (mService != null) {
+            try {
+                mService.setDuressFingerprint(userId, fpId);
+            } catch (RemoteException e) {
+                throw e.rethrowFromSystemServer();
+            }
+        } else {
+            Slog.w(TAG, "setDuressFingerprint(): Service not connected!");
+        }
+    }
+
+    /**
+     * Clears the currently configured duress fingerprint for the given user.
+     *
+     * @hide
+     */
+    @RequiresPermission(MANAGE_FINGERPRINT)
+    public void clearDuressFingerprint(int userId) {
+        setDuressFingerprint(userId, Fingerprint.DURESS_FINGERPRINT_NONE);
+    }
+
+    /**
+     * Returns the currently configured duress fingerprint for the given user.
+     *
+     * @hide
+     */
+    @RequiresPermission(MANAGE_FINGERPRINT)
+    @Nullable
+    public Fingerprint getDuressFingerprint(int userId) {
+        if (mService == null) {
+            Slog.w(TAG, "getDuressFingerprint(): Service not connected!");
+            return null;
+        }
+
+        final int duressId;
+        try {
+            duressId = mService.getDuressFingerprintId(userId);
+        } catch (RemoteException e) {
+            throw e.rethrowFromSystemServer();
+        }
+
+        if (duressId == Fingerprint.DURESS_FINGERPRINT_NONE) {
+            return null;
+        }
+
+        final List<Fingerprint> enrolled = getEnrolledFingerprints(userId);
+        if (enrolled == null) {
+            return null;
+        }
+
+        for (Fingerprint fingerprint : enrolled) {
+            if (fingerprint.getBiometricId() == duressId) {
+                return fingerprint;
+            }
+        }
+        return null;
+    }
