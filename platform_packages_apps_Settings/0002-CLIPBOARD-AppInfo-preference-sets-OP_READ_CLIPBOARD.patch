+package com.android.settings.spa.app.appinfo
+
+import android.app.AppOpsManager
+import android.app.AppOpsManager.MODE_IGNORED
+import android.app.AppOpsManager.OP_READ_CLIPBOARD
+import android.content.Context
+import android.content.pm.ApplicationInfo
+import androidx.compose.runtime.Composable
+import androidx.compose.runtime.remember
+import androidx.compose.ui.platform.LocalContext
+import androidx.lifecycle.compose.collectAsStateWithLifecycle
+import com.android.settings.R
+import com.android.settingslib.spa.framework.compose.OverridableFlow
+import com.android.settingslib.spa.widget.preference.SwitchPreference
+import com.android.settingslib.spa.widget.preference.SwitchPreferenceModel
+import com.android.settingslib.spaprivileged.framework.common.appOpsManager
+import com.android.settingslib.spaprivileged.model.app.installed
+import com.android.settingslib.spaprivileged.model.app.opModeFlow
+import kotlinx.coroutines.flow.map
+
+@Composable
+fun AppClipboardRestrictionSwitchPreference(app: ApplicationInfo) {
+    if (!app.installed) return
+
+    val context = LocalContext.current
+    val presenter = remember(app) { AppClipboardRestrictionPresenter(context, app) }
+    val isCheckedState = presenter.isCheckedFlow.collectAsStateWithLifecycle(initialValue = null)
+
+    SwitchPreference(remember {
+        object : SwitchPreferenceModel {
+            override val title = context.getString(R.string.restrict_clipboard_title)
+            override val summary = { context.getString(R.string.restrict_clipboard_summary) }
+
+            override val checked = { isCheckedState.value }
+            override val onCheckedChange = presenter::onCheckedChange
+        }
+    })
+}
+
+private class AppClipboardRestrictionPresenter(context: Context, private val app: ApplicationInfo) {
+    private val appOpsManager = context.appOpsManager
+    private val isChecked = OverridableFlow(
+        appOpsManager.opModeFlow(OP_READ_CLIPBOARD, app).map { it == MODE_IGNORED }
+    )
+
+    val isCheckedFlow = isChecked.flow
+
+    fun onCheckedChange(newChecked: Boolean) {
+        try {
+            val mode = if (newChecked) {
+                MODE_IGNORED
+            } else {
+                AppOpsManager.opToDefaultMode(OP_READ_CLIPBOARD)
+            }
+            appOpsManager.setMode(
+                OP_READ_CLIPBOARD,
+                app.uid,
+                app.packageName,
+                mode,
+            )
+            isChecked.override(newChecked)
+        } catch (_: RuntimeException) {
+        }
+    }
+}
