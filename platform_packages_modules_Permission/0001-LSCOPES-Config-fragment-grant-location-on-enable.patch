@@ -0,0 +1,45 @@
+package com.android.permissioncontroller.lscopes
+
+import android.content.Context
+import android.content.pm.GosPackageState
+import android.ext.lscopes.LocationScopesApi
+import android.os.UserHandle
+import android.widget.Button
+import com.android.permissioncontroller.R
+import com.android.permissioncontroller.permission.ui.GrantPermissionsActivity
+import com.android.permissioncontroller.permission.ui.handheld.ExtraPermissionLink
+
+object LocationScopesLinks : ExtraPermissionLink() {
+
+    override fun isVisible(ctx: Context, groupName: String, packageName: String, user: UserHandle) =
+            LocationScopesUtils.isLocationPermissionGroup(groupName)
+
+    override fun setupDialogButton(button: Button) {
+        button.setText(R.string.setup_location_scopes)
+    }
+
+    override fun onDialogButtonClick(activity: GrantPermissionsActivity, packageName: String) {
+        val intent = LocationScopesApi.createConfigActivityIntent(packageName)
+        @Suppress("DEPRECATION")
+        activity.startActivityForResult(intent, GrantPermissionsActivity.REQ_CODE_SETUP_LOCATION_SCOPES)
+    }
+
+    override fun getSettingsDeniedRadioButtonSuffix(ctx: Context, packageState: GosPackageState): String? = null
+
+    override fun getSettingsAllowedRadioButtonSuffix(ctx: Context, packageState: GosPackageState): String? {
+        if (LocationScopesUtils.isLocationScopesEnabled(packageState)) {
+            return " (" + ctx.getString(R.string.lscopes_allowed_suffix) + ")"
+        }
+
+        return null
+    }
+
+    override fun getSettingsLinkText(ctx: Context): CharSequence {
+        return ctx.getText(R.string.location_scopes)
+    }
+
+    override fun onSettingsLinkClick(ctx: Context, packageName: String, user: UserHandle) {
+        val intent = LocationScopesApi.createConfigActivityIntent(packageName)
+        ctx.startActivityAsUser(intent, user)
+    }
+}
diff --git a/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesUtils.kt b/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesUtils.kt
