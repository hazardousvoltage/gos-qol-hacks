+++ b/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesUtils.kt
@@ -0,0 +1,76 @@
+package com.android.permissioncontroller.lscopes
+
+import android.Manifest
+import android.app.AppOpsManager
+import android.content.Context
+import android.content.pm.GosPackageState
+import android.content.pm.GosPackageStateFlag
+import android.content.pm.PackageManager
+import android.os.Process
+import android.os.UserHandle
+import com.android.permissioncontroller.ext.ScopesUtils
+
+private val LOCATION_PERMISSION_GROUPS = setOf(
+    Manifest.permission_group.LOCATION
+)
+
+private val LOCATION_PERMISSIONS = ScopesUtils.getGroupPerms(LOCATION_PERMISSION_GROUPS)
+
+object LocationScopesUtils {
+
+    fun isLocationPermissionGroup(groupName: String): Boolean {
+        return LOCATION_PERMISSION_GROUPS.contains(groupName)
+    }
+
+    @JvmStatic
+    fun isLocationScopesEnabled(packageName: String, user: UserHandle): Boolean {
+        return isLocationScopesEnabled(GosPackageState.get(packageName, user))
+    }
+
+    fun isLocationScopesEnabled(ps: GosPackageState): Boolean {
+        return ps.hasFlag(GosPackageStateFlag.LOCATION_SCOPES_ENABLED)
+    }
+
+    fun revokeLocationPermissions(ctx: Context, packageName: String): Boolean {
+        return ScopesUtils.revokePermissions(ctx, packageName, LOCATION_PERMISSIONS)
+    }
+
+    // returns whether at least one permission/app-op state was changed
+    fun grantLocationPermissions(ctx: Context, packageName: String): Boolean {
+        val pm = ctx.packageManager
+        val uid = try {
+            pm.getPackageUid(packageName, 0)
+        } catch (_: PackageManager.NameNotFoundException) {
+            return false
+        }
+
+        val appOps = ctx.getSystemService(AppOpsManager::class.java)!!
+        val user = Process.myUserHandle()
+        var changed = false
+
+        // Grant foreground-only ("while using") access for fine and coarse location.
+        // ACCESS_BACKGROUND_LOCATION is intentionally excluded: enabling Location Scopes
+        // must not escalate to always-on access. Apps that need background location can
+        // request it through the normal runtime permission prompt.
+        for (permission in listOf(
+                Manifest.permission.ACCESS_FINE_LOCATION,
+                Manifest.permission.ACCESS_COARSE_LOCATION)) {
+            if (pm.checkPermission(permission, packageName) != PackageManager.PERMISSION_GRANTED) {
+                pm.grantRuntimePermission(packageName, permission, user)
+                changed = true
+            }
+
+            val op = AppOpsManager.permissionToOp(permission) ?: continue
+            // Only upgrade from an explicitly denied state. An existing MODE_ALLOWED
+            // ("always") grant is preserved — enabling Location Scopes must not demote it.
+            val currentMode = appOps.checkOpNoThrow(op, uid, packageName)
+            if (currentMode == AppOpsManager.MODE_IGNORED
+                    || currentMode == AppOpsManager.MODE_ERRORED) {
+                appOps.setUidMode(op, uid, AppOpsManager.MODE_FOREGROUND)
+                changed = true
+            }
+        }
+
+        return changed
+    }
+}
