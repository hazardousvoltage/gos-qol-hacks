diff --git a/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt b/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt
new file mode 100644
index 0000000000..dfea55571f
--- /dev/null
+++ b/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt
@@ -0,0 +1,344 @@
+package com.android.permissioncontroller.lscopes
+
+import android.content.Intent
+import android.content.pm.GosPackageState
+import android.content.pm.GosPackageStateFlag
+import android.ext.lscopes.LocationScopesApi
+import android.ext.lscopes.LocationScopesConfig
+import android.net.Uri
+import android.os.Bundle
+import android.text.InputType
+import androidx.annotation.StringRes
+import androidx.preference.EditTextPreference
+import androidx.preference.ListPreference
+import androidx.preference.Preference
+import com.android.permissioncontroller.R
+import com.android.permissioncontroller.ext.PackageExtraConfigFragment
+import com.android.permissioncontroller.ext.addOrRemove
+import com.android.permissioncontroller.ext.createFooterPreference
+import com.android.settingslib.widget.FooterPreference
+import com.android.settingslib.widget.MainSwitchPreference
+
+class LocationScopesFragment : PackageExtraConfigFragment() {
+    private lateinit var mainSwitch: MainSwitchPreference
+    private lateinit var modePreference: ListPreference
+    private lateinit var radiusPreference: EditTextPreference
+    private lateinit var latitudePreference: EditTextPreference
+    private lateinit var longitudePreference: EditTextPreference
+    private lateinit var altitudePreference: EditTextPreference
+    private lateinit var noisyTtlPreference: EditTextPreference
+    private lateinit var refreshNoisyLocationPreference: Preference
+    private lateinit var footer: FooterPreference
+
+    private var updatingUi = false
+
+    override fun onCreate(savedInstanceState: Bundle?) {
+        super.onCreate(savedInstanceState)
+
+        mainSwitch = MainSwitchPreference(context_).apply {
+            setTitle(R.string.lscopes_enable)
+            setOnPreferenceChangeListener { _, newValue ->
+                if (updatingUi) {
+                    return@setOnPreferenceChangeListener true
+                }
+                setLocationScopesEnabled(newValue as Boolean)
+                true
+            }
+        }
+
+        modePreference = ListPreference(context_).apply {
+            key = "mode"
+            setTitle(R.string.lscopes_mode)
+            entries = arrayOf(
+                getString(R.string.location_scopes_mode_normal),
+                getString(R.string.location_scopes_mode_noisy),
+                getString(R.string.location_scopes_mode_fixed),
+            )
+            entryValues = arrayOf(
+                LocationScopesApi.MODE_NORMAL.toString(),
+                LocationScopesApi.MODE_NOISY.toString(),
+                LocationScopesApi.MODE_FIXED.toString(),
+            )
+            setOnPreferenceChangeListener { _, newValue ->
+                if (updatingUi) {
+                    return@setOnPreferenceChangeListener true
+                }
+                val mode = (newValue as String).toIntOrNull() ?: return@setOnPreferenceChangeListener false
+                updateConfig { cfg ->
+                    LocationScopesConfig(
+                        mode,
+                        cfg.latitude,
+                        cfg.longitude,
+                        cfg.altitude,
+                        cfg.radiusMeters,
+                        cfg.noisyTtlMs,
+                        cfg.generation,
+                    )
+                }
+                true
+            }
+        }
+
+        radiusPreference = createNumberPreference(
+            key = "radius",
+            titleRes = R.string.lscopes_radius,
+            inputType = InputType.TYPE_CLASS_NUMBER or InputType.TYPE_NUMBER_FLAG_DECIMAL,
+        ) { value ->
+            val radius = value.toFloatOrNull()
+            if (radius == null || radius <= 0f) {
+                toastManager.showToast(R.string.lscopes_toast_invalid_radius)
+                return@createNumberPreference false
+            }
+            updateConfig { cfg ->
+                LocationScopesConfig(
+                    cfg.mode,
+                    cfg.latitude,
+                    cfg.longitude,
+                    cfg.altitude,
+                    radius,
+                    cfg.noisyTtlMs,
+                    cfg.generation,
+                )
+            }
+            true
+        }
+
+        latitudePreference = createNumberPreference(
+            key = "latitude",
+            titleRes = R.string.lscopes_latitude,
+            inputType = InputType.TYPE_CLASS_NUMBER or
+                InputType.TYPE_NUMBER_FLAG_DECIMAL or
+                InputType.TYPE_NUMBER_FLAG_SIGNED,
+        ) { value ->
+            val latitude = value.toDoubleOrNull()
+            if (latitude == null || latitude < -90.0 || latitude > 90.0) {
+                toastManager.showToast(R.string.lscopes_toast_invalid_latitude)
+                return@createNumberPreference false
+            }
+            updateConfig { cfg ->
+                LocationScopesConfig(
+                    cfg.mode,
+                    latitude,
+                    cfg.longitude,
+                    cfg.altitude,
+                    cfg.radiusMeters,
+                    cfg.noisyTtlMs,
+                    cfg.generation,
+                )
+            }
+            true
+        }
+
+        longitudePreference = createNumberPreference(
+            key = "longitude",
+            titleRes = R.string.lscopes_longitude,
+            inputType = InputType.TYPE_CLASS_NUMBER or
+                InputType.TYPE_NUMBER_FLAG_DECIMAL or
+                InputType.TYPE_NUMBER_FLAG_SIGNED,
+        ) { value ->
+            val longitude = value.toDoubleOrNull()
+            if (longitude == null || longitude < -180.0 || longitude > 180.0) {
+                toastManager.showToast(R.string.lscopes_toast_invalid_longitude)
+                return@createNumberPreference false
+            }
+            updateConfig { cfg ->
+                LocationScopesConfig(
+                    cfg.mode,
+                    cfg.latitude,
+                    longitude,
+                    cfg.altitude,
+                    cfg.radiusMeters,
+                    cfg.noisyTtlMs,
+                    cfg.generation,
+                )
+            }
+            true
+        }
+
+        altitudePreference = createNumberPreference(
+            key = "altitude",
+            titleRes = R.string.lscopes_altitude,
+            inputType = InputType.TYPE_CLASS_NUMBER or
+                InputType.TYPE_NUMBER_FLAG_DECIMAL or
+                InputType.TYPE_NUMBER_FLAG_SIGNED,
+        ) { value ->
+            val altitude = value.toDoubleOrNull()
+            if (altitude == null) {
+                toastManager.showToast(R.string.lscopes_toast_invalid_altitude)
+                return@createNumberPreference false
+            }
+            updateConfig { cfg ->
+                LocationScopesConfig(
+                    cfg.mode,
+                    cfg.latitude,
+                    cfg.longitude,
+                    altitude,
+                    cfg.radiusMeters,
+                    cfg.noisyTtlMs,
+                    cfg.generation,
+                )
+            }
+            true
+        }
+
+        noisyTtlPreference = createNumberPreference(
+            key = "noisy_ttl",
+            titleRes = R.string.lscopes_noisy_ttl,
+            inputType = InputType.TYPE_CLASS_NUMBER,
+        ) { value ->
+            val ttlSecs = value.toLongOrNull()
+            if (ttlSecs == null || ttlSecs <= 0L) {
+                toastManager.showToast(R.string.lscopes_toast_invalid_ttl)
+                return@createNumberPreference false
+            }
+            updateConfig { cfg ->
+                LocationScopesConfig(
+                    cfg.mode,
+                    cfg.latitude,
+                    cfg.longitude,
+                    cfg.altitude,
+                    cfg.radiusMeters,
+                    ttlSecs * 1000L,
+                    cfg.generation,
+                )
+            }
+            true
+        }
+
+        refreshNoisyLocationPreference = Preference(context_).apply {
+            key = "refresh_noisy_location"
+            setTitle(R.string.lscopes_refresh_noisy_location)
+            setOnPreferenceClickListener {
+                updateConfig { cfg ->
+                    LocationScopesConfig(
+                        cfg.mode,
+                        cfg.latitude,
+                        cfg.longitude,
+                        cfg.altitude,
+                        cfg.radiusMeters,
+                        cfg.noisyTtlMs,
+                        cfg.generation + 1,
+                    )
+                }
+                true
+            }
+        }
+
+        footer = createFooterPreference().apply {
+            setLearnMoreAction {
+                startActivity(Intent(Intent.ACTION_VIEW, Uri.parse("https://grapheneos.org/usage#location-scopes")))
+            }
+        }
+
+        update()
+    }
+
+    override fun getTitle(): CharSequence = getString(R.string.location_scopes)
+
+    override fun update() {
+        val packageState = getGosPackageState()
+        val enabled = packageState.hasFlag(GosPackageStateFlag.LOCATION_SCOPES_ENABLED)
+        val config = getConfig(packageState)
+
+        updatingUi = true
+        mainSwitch.isChecked = enabled
+        modePreference.value = config.mode.toString()
+        modePreference.summary = modeLabel(config.mode)
+        radiusPreference.text = config.radiusMeters.toString()
+        radiusPreference.summary = config.radiusMeters.toString()
+        latitudePreference.text = config.latitude.toString()
+        latitudePreference.summary = config.latitude.toString()
+        longitudePreference.text = config.longitude.toString()
+        longitudePreference.summary = config.longitude.toString()
+        altitudePreference.text = config.altitude.toString()
+        altitudePreference.summary = config.altitude.toString()
+        val ttlSecs = (config.noisyTtlMs / 1000).toString()
+        noisyTtlPreference.text = ttlSecs
+        noisyTtlPreference.summary = ttlSecs
+        updatingUi = false
+
+        addOrRemove(mainSwitch, true)
+        addOrRemove(modePreference, enabled)
+
+        val showNoisyControls = enabled && config.mode == LocationScopesApi.MODE_NOISY
+        addOrRemove(radiusPreference, showNoisyControls)
+        addOrRemove(noisyTtlPreference, showNoisyControls)
+        addOrRemove(refreshNoisyLocationPreference, showNoisyControls)
+
+        val showFixedCoordinates = enabled && config.mode == LocationScopesApi.MODE_FIXED
+        addOrRemove(latitudePreference, showFixedCoordinates)
+        addOrRemove(longitudePreference, showFixedCoordinates)
+        addOrRemove(altitudePreference, showFixedCoordinates)
+
+        footer.setSummary(if (enabled) R.string.lscopes_enabled_footer else R.string.lscopes_disabled_footer)
+        addOrRemove(footer, true)
+    }
+
+    private fun createNumberPreference(
+        key: String,
+        @StringRes titleRes: Int,
+        inputType: Int,
+        onChange: (String) -> Boolean,
+    ): EditTextPreference {
+        return EditTextPreference(context_).apply {
+            this.key = key
+            setTitle(titleRes)
+            setOnBindEditTextListener {
+                it.inputType = inputType
+                it.selectAll()
+            }
+            setOnPreferenceChangeListener { _, newValue ->
+                if (updatingUi) {
+                    return@setOnPreferenceChangeListener true
+                }
+                onChange(newValue as String)
+            }
+        }
+    }
+
+    private fun getConfig(packageState: GosPackageState): LocationScopesConfig {
+        return LocationScopesConfig.deserialize(packageState.locationScopes)
+    }
+
+    private fun updateConfig(transform: (LocationScopesConfig) -> LocationScopesConfig) {
+        val packageState = getGosPackageState()
+        val current = getConfig(packageState)
+        val updated = transform(current)
+
+        packageState.createEditor(pkgName, context_.user).run {
+            setFlagState(GosPackageStateFlag.LOCATION_SCOPES_ENABLED, true)
+            setLocationScopes(updated.serialize())
+            setKillUidAfterApply(false)
+            setNotifyUidAfterApply(true)
+            applyOrPressBack()
+        }
+    }
+
+    private fun setLocationScopesEnabled(enabled: Boolean) {
+        if (enabled && LocationScopesUtils.grantLocationPermissions(context_, pkgName)) {
+            toastManager.showToast(R.string.lscopes_toast_location_permissions_granted)
+        }
+
+        val config = if (enabled) {
+            getConfig(getGosPackageState()).serialize()
+        } else {
+            null
+        }
+
+        GosPackageState.edit(pkgName, context_.user).run {
+            setFlagState(GosPackageStateFlag.LOCATION_SCOPES_ENABLED, enabled)
+            setLocationScopes(config)
+            setKillUidAfterApply(true)
+            setNotifyUidAfterApply(true)
+            applyOrPressBack()
+        }
+    }
+
+    private fun modeLabel(mode: Int): String {
+        return when (mode) {
+            LocationScopesApi.MODE_NORMAL -> getString(R.string.location_scopes_mode_normal)
+            LocationScopesApi.MODE_FIXED -> getString(R.string.location_scopes_mode_fixed)
+            else -> getString(R.string.location_scopes_mode_noisy)
+        }
+    }
+}
