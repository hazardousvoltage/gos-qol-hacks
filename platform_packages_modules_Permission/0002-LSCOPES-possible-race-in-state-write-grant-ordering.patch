From b1775db71514b79794f46aa5a77b48fc15a4a256 Mon Sep 17 00:00:00 2001
From: Hazardous Voltage <104310555+hazardousvoltage@users.noreply.github.com>
Date: Tue, 19 May 2026 20:02:12 -0500
Subject: [PATCH 2/3] LSCOPES: possible race in state write/grant ordering

---
 .../lscopes/LocationScopesFragment.kt         | 31 ++++++++++++++-----
 1 file changed, 24 insertions(+), 7 deletions(-)

diff --git a/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt b/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt
index dfea55571f..15652ad4c3 100644
--- a/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt
+++ b/PermissionController/src/com/android/permissioncontroller/lscopes/LocationScopesFragment.kt
@@ -16,6 +16,7 @@ import com.android.permissioncontroller.R
 import com.android.permissioncontroller.ext.PackageExtraConfigFragment
 import com.android.permissioncontroller.ext.addOrRemove
 import com.android.permissioncontroller.ext.createFooterPreference
+import com.android.permissioncontroller.permission.ui.handheld.pressBack
 import com.android.settingslib.widget.FooterPreference
 import com.android.settingslib.widget.MainSwitchPreference
 
@@ -315,23 +316,39 @@ class LocationScopesFragment : PackageExtraConfigFragment() {
     }
 
     private fun setLocationScopesEnabled(enabled: Boolean) {
-        if (enabled && LocationScopesUtils.grantLocationPermissions(context_, pkgName)) {
-            toastManager.showToast(R.string.lscopes_toast_location_permissions_granted)
-        }
-
         val config = if (enabled) {
             getConfig(getGosPackageState()).serialize()
         } else {
             null
         }
 
-        GosPackageState.edit(pkgName, context_.user).run {
+        val psUpdated = GosPackageState.edit(pkgName, context_.user).run {
             setFlagState(GosPackageStateFlag.LOCATION_SCOPES_ENABLED, enabled)
             setLocationScopes(config)
-            setKillUidAfterApply(true)
+            setKillUidAfterApply(shouldKillUidAfterScopesToggle(enabled))
             setNotifyUidAfterApply(true)
-            applyOrPressBack()
+            apply()
+        }
+        if (!psUpdated) {
+            pressBack()
+            return
+        }
+
+        if (enabled && LocationScopesUtils.grantLocationPermissions(context_, pkgName)) {
+            toastManager.showToast(R.string.lscopes_toast_location_permissions_granted)
+        }
+
+        update()
+    }
+
+    private fun shouldKillUidAfterScopesToggle(enabled: Boolean): Boolean {
+        if (!enabled) {
+            return true
         }
+
+        // When launched from the runtime permission dialog, killing the target UID here can
+        // prevent the app from receiving the permission result it is waiting for.
+        return requireActivity().callingActivity == null
     }
 
     private fun modeLabel(mode: Int): String {
